{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "chrome",
      "request": "launch",
      "name": "Debug: Launch & Serve",
      "preLaunchTask": "Serve Project",
      "file": "${workspaceFolder}/index.html",
      "webRoot": "${workspaceFolder}"
    },
    {
      "type": "chrome",
      "request": "launch",
      "name": "Debug: file://",
      "file": "${workspaceFolder}/index.html",
      "webRoot": "${workspaceFolder}"
    },
    {
      "type": "node",
      "request": "launch",
      "name": "Debug: Run Tests",
      "program": "${workspaceFolder}/js/tests/helpers.test.js",
      "console": "integratedTerminal"
    }
  ]
}
